# ── Portfolio Optimizer — Backend Environment ──────────────────────
# Copy this file to .env and fill in your values.

# Google Gemini API Key (required for AI Research tab)
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Risk-free rate — India 91-day T-bill (decimal, e.g. 0.068 = 6.8%)
# RISK_FREE_RATE=0.068

# Cache TTLs in seconds
# PRICE_CACHE_TTL=120
# HISTORICAL_CACHE_TTL=1800
